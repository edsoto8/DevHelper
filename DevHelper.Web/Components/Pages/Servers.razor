@page "/servers"
@rendermode InteractiveServer
@inject IServerRepository ServerRepository
@inject ISystemRepository SystemRepository

<PageTitle>Servers</PageTitle>

<h1>Servers</h1>
<p class="text-muted">Maintain the shared list of servers.</p>

<div class="card mb-4">
    <div class="card-body">
        <h5 class="card-title">@(_editing.Id == 0 ? "Add server" : $"Edit server #{_editing.Id}")</h5>
        <div class="row g-2">
            <div class="col-md-3">
                <label class="form-label">Name</label>
                <input class="form-control" @bind="_editing.Name" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Environment</label>
                <select class="form-select" @bind="_editing.Environment">
                    @foreach (var env in Environments.All)
                    {
                        <option value="@env">@env</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Type</label>
                <select class="form-select" @bind="_editing.ServerType">
                    @foreach (var type in ServerTypes.All)
                    {
                        <option value="@type">@type</option>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Related system</label>
                <select class="form-select" @bind="_editing.SystemEntryId">
                    <option value="">(none)</option>
                    @foreach (var system in _systems)
                    {
                        <option value="@system.Id">@system.Name</option>
                    }
                </select>
            </div>
            <div class="col-12">
                <label class="form-label">Notes</label>
                <input class="form-control" @bind="_editing.Notes" />
            </div>
            <div class="col-12 d-flex gap-2">
                <button class="btn btn-primary" @onclick="SaveAsync" disabled="@string.IsNullOrWhiteSpace(_editing.Name)">Save</button>
                @if (_editing.Id != 0)
                {
                    <button class="btn btn-secondary" @onclick="ResetForm">Cancel</button>
                }
            </div>
        </div>
    </div>
</div>

<table class="table table-striped">
    <thead>
        <tr><th>Name</th><th>Environment</th><th>Type</th><th>System</th><th>Active</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var server in _servers)
        {
            <tr>
                <td>@server.Name</td>
                <td>@server.Environment</td>
                <td>@server.ServerType</td>
                <td>@SystemName(server.SystemEntryId)</td>
                <td>@(server.IsActive ? "Yes" : "No")</td>
                <td class="text-end">
                    <button class="btn btn-sm btn-outline-primary" @onclick="() => Edit(server)">Edit</button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => ToggleActiveAsync(server)">
                        @(server.IsActive ? "Deactivate" : "Activate")
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private List<ServerEntry> _servers = new();
    private List<SystemEntry> _systems = new();
    private ServerEntry _editing = NewEntry();

    private static ServerEntry NewEntry() => new()
    {
        Environment = Environments.Development,
        ServerType = ServerTypes.Web,
    };

    protected override async Task OnInitializedAsync()
    {
        _systems = (await SystemRepository.GetAllAsync(includeInactive: true)).ToList();
        await LoadAsync();
    }

    private async Task LoadAsync()
        => _servers = (await ServerRepository.GetAllAsync(includeInactive: true)).ToList();

    private string SystemName(long? id)
        => id is { } value ? _systems.FirstOrDefault(s => s.Id == value)?.Name ?? "" : "";

    private void Edit(ServerEntry server)
        => _editing = new ServerEntry
        {
            Id = server.Id, Name = server.Name, Environment = server.Environment,
            SystemEntryId = server.SystemEntryId, ServerType = server.ServerType,
            Notes = server.Notes, IsActive = server.IsActive,
        };

    private void ResetForm() => _editing = NewEntry();

    private async Task SaveAsync()
    {
        if (_editing.Id == 0)
        {
            await ServerRepository.CreateAsync(_editing);
        }
        else
        {
            await ServerRepository.UpdateAsync(_editing);
        }

        ResetForm();
        await LoadAsync();
    }

    private async Task ToggleActiveAsync(ServerEntry server)
    {
        await ServerRepository.SetActiveAsync(server.Id, !server.IsActive);
        await LoadAsync();
    }
}
