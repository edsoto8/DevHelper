@page "/systems"
@rendermode InteractiveServer
@inject ISystemRepository SystemRepository

<PageTitle>Systems</PageTitle>

<h1>Systems</h1>
<p class="text-muted">Maintain the shared list of systems used by release and test plans.</p>

<div class="card mb-4">
    <div class="card-body">
        <h5 class="card-title">@(_editing.Id == 0 ? "Add system" : $"Edit system #{_editing.Id}")</h5>
        <div class="row g-2">
            <div class="col-md-4">
                <label class="form-label">Name</label>
                <input class="form-control" @bind="_editing.Name" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Description</label>
                <input class="form-control" @bind="_editing.Description" />
            </div>
            <div class="col-md-2 d-flex align-items-end gap-2">
                <button class="btn btn-primary" @onclick="SaveAsync" disabled="@string.IsNullOrWhiteSpace(_editing.Name)">Save</button>
                @if (_editing.Id != 0)
                {
                    <button class="btn btn-secondary" @onclick="ResetForm">Cancel</button>
                }
            </div>
        </div>
    </div>
</div>

<table class="table table-striped">
    <thead>
        <tr><th>Name</th><th>Description</th><th>Active</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var system in _systems)
        {
            <tr>
                <td>@system.Name</td>
                <td>@system.Description</td>
                <td>@(system.IsActive ? "Yes" : "No")</td>
                <td class="text-end">
                    <button class="btn btn-sm btn-outline-primary" @onclick="() => Edit(system)">Edit</button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => ToggleActiveAsync(system)">
                        @(system.IsActive ? "Deactivate" : "Activate")
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private List<SystemEntry> _systems = new();
    private SystemEntry _editing = new();

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
        => _systems = (await SystemRepository.GetAllAsync(includeInactive: true)).ToList();

    private void Edit(SystemEntry system)
        => _editing = new SystemEntry
        {
            Id = system.Id, Name = system.Name, Description = system.Description, IsActive = system.IsActive,
        };

    private void ResetForm() => _editing = new SystemEntry();

    private async Task SaveAsync()
    {
        if (_editing.Id == 0)
        {
            await SystemRepository.CreateAsync(_editing);
        }
        else
        {
            await SystemRepository.UpdateAsync(_editing);
        }

        ResetForm();
        await LoadAsync();
    }

    private async Task ToggleActiveAsync(SystemEntry system)
    {
        await SystemRepository.SetActiveAsync(system.Id, !system.IsActive);
        await LoadAsync();
    }
}
