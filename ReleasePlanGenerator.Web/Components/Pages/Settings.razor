@page "/settings"
@rendermode InteractiveServer
@inject IApplicationSettingsService SettingsService
@inject IExternalSqlServerConnectionService SqlConnectionService

<PageTitle>Settings</PageTitle>

<h1>Settings</h1>

@if (_loading)
{
    <p>Loading…</p>
}
else
{
    <div class="card mb-4">
        <div class="card-header fw-bold">External SQL Server (Ticket Lookup)</div>
        <div class="card-body">
            <p class="text-muted small">
                Optional. Configure a SQL Server connection string for future ticket lookup.
                The connection string is stored encrypted.
            </p>
            <div class="mb-3">
                <label class="form-label">Connection String</label>
                <input type="password" class="form-control font-monospace"
                       @bind="_sqlConnectionString"
                       placeholder="Server=…;Database=…;Trusted_Connection=True;" />
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-primary" @onclick="SaveSqlConnection">Save</button>
                <button class="btn btn-outline-secondary" @onclick="TestConnection"
                        disabled="@string.IsNullOrWhiteSpace(_sqlConnectionString)">
                    Test Connection
                </button>
            </div>
            @if (_connectionTestResult.HasValue)
            {
                <div class="alert @(_connectionTestResult.Value ? "alert-success" : "alert-danger") mt-2">
                    @(_connectionTestResult.Value ? "Connection successful." : "Connection failed. Check the logs for details.")
                </div>
            }
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_saved))
    {
        <div class="alert alert-success">@_saved</div>
    }
}

@code {
    private string? _sqlConnectionString;
    private bool? _connectionTestResult;
    private string? _saved;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _sqlConnectionString = await SettingsService.GetExternalSqlServerConnectionStringAsync();
        _loading = false;
    }

    private async Task SaveSqlConnection()
    {
        await SettingsService.SetExternalSqlServerConnectionStringAsync(_sqlConnectionString);
        _saved = "Settings saved.";
        _connectionTestResult = null;
    }

    private async Task TestConnection()
    {
        _connectionTestResult = null;
        if (!string.IsNullOrWhiteSpace(_sqlConnectionString))
            _connectionTestResult = await SqlConnectionService.TestConnectionAsync(_sqlConnectionString);
    }
}
