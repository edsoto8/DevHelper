@page "/servers"
@rendermode InteractiveServer
@using ReleasePlanGenerator.Web.Repositories
@inject IServerRepository ServerRepo
@inject ISystemRepository SystemRepo

<PageTitle>Servers</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Servers</h1>
    <button class="btn btn-primary" @onclick="NewServer">+ Add Server</button>
</div>

@if (_loading)
{
    <p>Loading…</p>
}
else
{
    <table class="table table-hover">
        <thead><tr><th>Name</th><th>Environment</th><th>Type</th><th>System</th><th>Active</th><th></th></tr></thead>
        <tbody>
            @foreach (var s in _servers)
            {
                <tr>
                    <td>@s.Name</td>
                    <td>@s.Environment</td>
                    <td>@s.ServerType</td>
                    <td>@(_systems.FirstOrDefault(sys => sys.Id == s.SystemEntryId)?.Name ?? "—")</td>
                    <td>@(s.IsActive ? "Active" : "Inactive")</td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary" @onclick="() => Edit(s)">Edit</button>
                        @if (s.IsActive)
                        {
                            <button class="btn btn-sm btn-outline-danger ms-1" @onclick="() => Deactivate(s.Id)">Deactivate</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (_editing is not null)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.4)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editing.Id == 0 ? "Add" : "Edit") Server</h5>
                    <button type="button" class="btn-close" @onclick="CancelEdit"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-2">
                        <div class="col-12">
                            <label class="form-label">Name <span class="text-danger">*</span></label>
                            <input class="form-control" @bind="_editing.Name" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Environment <span class="text-danger">*</span></label>
                            <select class="form-select" @bind="_editing.Environment">
                                <option value="">— Select —</option>
                                <option>Development</option><option>QA</option>
                                <option>UAT</option><option>Production</option><option>Other</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Server Type</label>
                            <select class="form-select" @bind="_editing.ServerType">
                                <option value="">— Select —</option>
                                <option>Web Server</option><option>App Server</option>
                                <option>Database Server</option><option>File Server</option>
                                <option>Service Server</option><option>Other</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Related System</label>
                            <select class="form-select" @bind="_editing.SystemEntryId">
                                <option value="">— None —</option>
                                @foreach (var sys in _systems)
                                {
                                    <option value="@sys.Id">@sys.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Notes</label>
                            <textarea class="form-control" rows="2" @bind="_editing.Notes"></textarea>
                        </div>
                        <div class="col-12">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" @bind="_editing.IsActive" id="srvActive" />
                                <label class="form-check-label" for="srvActive">Active</label>
                            </div>
                        </div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(_formError))
                    {
                        <div class="alert alert-danger mt-2">@_formError</div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CancelEdit">Cancel</button>
                    <button class="btn btn-primary" @onclick="SaveServer">Save</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<ServerEntry> _servers = [];
    private List<SystemEntry> _systems = [];
    private bool _loading = true;
    private ServerEntry? _editing;
    private string? _formError;

    protected override async Task OnInitializedAsync()
    {
        _servers = (await ServerRepo.GetAllAsync()).ToList();
        _systems = (await SystemRepo.GetActiveAsync()).ToList();
        _loading = false;
    }

    private void NewServer() => _editing = new ServerEntry { IsActive = true };
    private void Edit(ServerEntry s) => _editing = new ServerEntry
    {
        Id = s.Id, Name = s.Name, Environment = s.Environment, SystemEntryId = s.SystemEntryId,
        ServerType = s.ServerType, Notes = s.Notes, IsActive = s.IsActive
    };
    private void CancelEdit() { _editing = null; _formError = null; }

    private async Task SaveServer()
    {
        if (_editing is null) return;
        if (string.IsNullOrWhiteSpace(_editing.Name)) { _formError = "Name is required."; return; }
        if (string.IsNullOrWhiteSpace(_editing.Environment)) { _formError = "Environment is required."; return; }
        if (_editing.Id == 0) await ServerRepo.CreateAsync(_editing);
        else await ServerRepo.UpdateAsync(_editing);
        _editing = null; _formError = null;
        _servers = (await ServerRepo.GetAllAsync()).ToList();
    }

    private async Task Deactivate(int id)
    {
        await ServerRepo.DeactivateAsync(id);
        _servers = (await ServerRepo.GetAllAsync()).ToList();
    }
}
