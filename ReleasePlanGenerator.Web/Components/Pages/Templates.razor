@page "/templates"
@rendermode InteractiveServer
@using ReleasePlanGenerator.Web.Repositories
@inject IReleaseTemplateRepository TemplateRepo

<PageTitle>Templates</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Templates</h1>
    <button class="btn btn-primary" @onclick="NewTemplate">+ New Template</button>
</div>

@if (_loading)
{
    <p>Loading…</p>
}
else
{
    <table class="table table-hover">
        <thead>
            <tr><th>Name</th><th>Description</th><th>Default</th><th>Active</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var t in _templates)
            {
                <tr>
                    <td>@t.Name</td>
                    <td>@t.Description</td>
                    <td>@(t.IsDefault ? "✓" : "")</td>
                    <td>@(t.IsActive ? "Active" : "Inactive")</td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary" @onclick="() => Edit(t)">Edit</button>
                        @if (!t.IsDefault)
                        {
                            <button class="btn btn-sm btn-outline-secondary ms-1" @onclick="() => SetDefault(t.Id)">Set Default</button>
                        }
                        <button class="btn btn-sm btn-outline-info ms-1" @onclick="() => Duplicate(t)">Duplicate</button>
                        @if (t.IsActive)
                        {
                            <button class="btn btn-sm btn-outline-danger ms-1" @onclick="() => Deactivate(t.Id)">Deactivate</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (_editing is not null)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.4)">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editing.Id == 0 ? "New" : "Edit") Template</h5>
                    <button type="button" class="btn-close" @onclick="CancelEdit"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Name <span class="text-danger">*</span></label>
                        <input class="form-control" @bind="_editing.Name" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <input class="form-control" @bind="_editing.Description" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Markdown Template <span class="text-danger">*</span></label>
                        <textarea class="form-control font-monospace" rows="20" @bind="_editing.MarkdownTemplate"></textarea>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" @bind="_editing.IsActive" id="tplActive" />
                        <label class="form-check-label" for="tplActive">Active</label>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(_formError))
                    {
                        <div class="alert alert-danger mt-2">@_formError</div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CancelEdit">Cancel</button>
                    <button class="btn btn-primary" @onclick="SaveTemplate">Save</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<ReleaseTemplate> _templates = [];
    private bool _loading = true;
    private ReleaseTemplate? _editing;
    private string? _formError;

    protected override async Task OnInitializedAsync()
    {
        await Reload();
        _loading = false;
    }

    private async Task Reload() =>
        _templates = (await TemplateRepo.GetAllAsync()).ToList();

    private void NewTemplate() =>
        _editing = new ReleaseTemplate { IsActive = true, MarkdownTemplate = string.Empty };

    private void Edit(ReleaseTemplate t) =>
        _editing = new ReleaseTemplate
        {
            Id = t.Id, Name = t.Name, Description = t.Description,
            MarkdownTemplate = t.MarkdownTemplate, IsDefault = t.IsDefault, IsActive = t.IsActive
        };

    private void CancelEdit() { _editing = null; _formError = null; }

    private async Task SaveTemplate()
    {
        if (_editing is null) return;
        if (string.IsNullOrWhiteSpace(_editing.Name)) { _formError = "Name is required."; return; }
        if (string.IsNullOrWhiteSpace(_editing.MarkdownTemplate)) { _formError = "Template content is required."; return; }

        if (_editing.Id == 0) await TemplateRepo.CreateAsync(_editing);
        else await TemplateRepo.UpdateAsync(_editing);

        _editing = null;
        _formError = null;
        await Reload();
    }

    private async Task SetDefault(int id)
    {
        await TemplateRepo.SetDefaultAsync(id);
        await Reload();
    }

    private async Task Duplicate(ReleaseTemplate t)
    {
        var copy = new ReleaseTemplate
        {
            Name = $"{t.Name} (Copy)", Description = t.Description,
            MarkdownTemplate = t.MarkdownTemplate, IsActive = true
        };
        await TemplateRepo.CreateAsync(copy);
        await Reload();
    }

    private async Task Deactivate(int id)
    {
        await TemplateRepo.DeleteAsync(id);
        await Reload();
    }
}
