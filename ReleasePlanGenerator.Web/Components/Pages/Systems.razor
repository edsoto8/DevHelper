@page "/systems"
@rendermode InteractiveServer
@using ReleasePlanGenerator.Web.Repositories
@inject ISystemRepository SystemRepo

<PageTitle>Systems</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Systems</h1>
    <button class="btn btn-primary" @onclick="NewSystem">+ Add System</button>
</div>

@if (_loading)
{
    <p>Loading…</p>
}
else
{
    <table class="table table-hover">
        <thead><tr><th>Name</th><th>Description</th><th>Active</th><th></th></tr></thead>
        <tbody>
            @foreach (var s in _systems)
            {
                <tr>
                    <td>@s.Name</td>
                    <td>@s.Description</td>
                    <td>@(s.IsActive ? "Active" : "Inactive")</td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary" @onclick="() => Edit(s)">Edit</button>
                        @if (s.IsActive)
                        {
                            <button class="btn btn-sm btn-outline-danger ms-1" @onclick="() => Deactivate(s.Id)">Deactivate</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (_editing is not null)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.4)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editing.Id == 0 ? "Add" : "Edit") System</h5>
                    <button type="button" class="btn-close" @onclick="CancelEdit"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Name <span class="text-danger">*</span></label>
                        <input class="form-control" @bind="_editing.Name" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <input class="form-control" @bind="_editing.Description" />
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" @bind="_editing.IsActive" id="sysActive" />
                        <label class="form-check-label" for="sysActive">Active</label>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(_formError))
                    {
                        <div class="alert alert-danger mt-2">@_formError</div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CancelEdit">Cancel</button>
                    <button class="btn btn-primary" @onclick="SaveSystem">Save</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<SystemEntry> _systems = [];
    private bool _loading = true;
    private SystemEntry? _editing;
    private string? _formError;

    protected override async Task OnInitializedAsync()
    {
        _systems = (await SystemRepo.GetAllAsync()).ToList();
        _loading = false;
    }

    private void NewSystem() => _editing = new SystemEntry { IsActive = true };
    private void Edit(SystemEntry s) => _editing = new SystemEntry { Id = s.Id, Name = s.Name, Description = s.Description, IsActive = s.IsActive };
    private void CancelEdit() { _editing = null; _formError = null; }

    private async Task SaveSystem()
    {
        if (_editing is null) return;
        if (string.IsNullOrWhiteSpace(_editing.Name)) { _formError = "Name is required."; return; }
        if (_editing.Id == 0) await SystemRepo.CreateAsync(_editing);
        else await SystemRepo.UpdateAsync(_editing);
        _editing = null; _formError = null;
        _systems = (await SystemRepo.GetAllAsync()).ToList();
    }

    private async Task Deactivate(int id)
    {
        await SystemRepo.DeactivateAsync(id);
        _systems = (await SystemRepo.GetAllAsync()).ToList();
    }
}
