{
  "ConnectionStrings": {
    "Sqlite": "Data Source=release-plan-generator.db",
    "ExternalSqlServer": ""
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/release-plan-generator-.log",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
